# Google Cloud / Vertex AI credentials
# Set these to your GCP project before running any evaluation.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: path to a service account key JSON file.
# If not set, Application Default Credentials (ADC) will be used instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Optional: Confident AI cloud reporting (disabled by default)
# ENABLE_CONFIDENT_CLOUD=0
# CONFIDENT_API_KEY=your-confident-api-key
